<?xml version="1.0"?>
<robot name="exam_robot">

    <!-- Материалы -->
    <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
    </material>
    <material name="black">
        <color rgba="0.0 0.0 0.0 1.0"/>
    </material>
    <material name="red">
        <color rgba="1.0 0.0 0.0 1.0"/>
    </material>

    <!-- BASE_LINK -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.4 0.3 0.1"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <!-- LEFT_WHEEL -->
    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.04"/>
            </geometry>
            <!-- Поворачиваем цилиндр на 90° вокруг Y, чтобы колесо было вертикально -->
            <origin rpy="1.5708 0 0"/>  <!-- 90° вокруг Y -->
            <material name="black"/>
        </visual>
    </link>

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 0.17 -0.02" rpy="0 0 0"/>  <!-- Смещение по z, чтобы колесо было ниже -->
        <axis xyz="0 0 1"/>
    </joint>

    <!-- RIGHT_WHEEL -->
    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.08" length="0.04"/>
            </geometry>
            <origin rpy="1.5708 0 0"/>
            <material name="black"/>
        </visual>
    </link>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.17 -0.02" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- SENSOR_LINK -->
    <link name="sensor_link">
        <visual>
            <geometry>
                <box size="0.05 0.05 0.05"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

    <joint name="sensor_joint" type="fixed">
        <parent link="base_link"/>
        <child link="sensor_link"/>
        <origin xyz="0.2 0 0.08" rpy="0 0 0"/>
    </joint>

</robot>